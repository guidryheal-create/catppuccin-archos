#!/usr/bin/env bash
set -euo pipefail

app_title="Kitten: Apply Catppuccin (Kvantum)"

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || {
    printf '%s\n' "$app_title: missing dependency: $1" >&2
    exit 1
  }
}

need_cmd kdialog

theme_root=""
if [[ -d "/usr/share/kvantum/themes" ]] && compgen -G "/usr/share/kvantum/themes/*" >/dev/null 2>&1; then
  theme_root="/usr/share/kvantum/themes"
elif [[ -d "/usr/share/kitten-themes/kvantum" ]]; then
  theme_root="/usr/share/kitten-themes/kvantum"
fi
config_dir="${XDG_CONFIG_HOME:-$HOME/.config}"
kvantum_conf="$config_dir/Kvantum/kvantum.kvconfig"
kvantum_user_themes="$config_dir/Kvantum/themes"
qt5ct_conf="$config_dir/qt5ct/qt5ct.conf"
qt6ct_conf="$config_dir/qt6ct/qt6ct.conf"
plasma_env_dir="$config_dir/plasma-workspace/env"
plasma_env_file="$plasma_env_dir/kitten-qt-platformtheme.sh"

if [[ -z "$theme_root" || ! -d "$theme_root" ]]; then
  kdialog --title "$app_title" --error "No bundled Catppuccin Kvantum themes found under:\n/usr/share/kvantum/themes\n(or legacy /usr/share/kitten-themes/kvantum)\n\nRebuild the ISO with KITEST_BUNDLE_CATPPUCCIN_KVANTUM=1 (default), or use the Theme Selector to install manually." 2>/dev/null || true
  exit 1
fi

mapfile -t theme_dirs < <(ls -1 "$theme_root" 2>/dev/null | sort -V)
if [[ "${#theme_dirs[@]}" -eq 0 ]]; then
  kdialog --title "$app_title" --error "No Kvantum themes found in:\n$theme_root" 2>/dev/null || true
  exit 1
fi

# Prefer a Mocha-like theme if present; otherwise pick the first directory.
selected_theme=""
for d in "${theme_dirs[@]}"; do
  if [[ -d "$theme_root/$d" ]] && printf '%s' "$d" | grep -qi mocha; then
    selected_theme="$d"
    break
  fi
done
if [[ -z "$selected_theme" ]]; then
  for d in "${theme_dirs[@]}"; do
    [[ -d "$theme_root/$d" ]] || continue
    selected_theme="$d"
    break
  done
fi

[[ -n "$selected_theme" ]] || exit 1

mkdir -p "$kvantum_user_themes" "$(dirname "$kvantum_conf")" "$plasma_env_dir" "$(dirname "$qt5ct_conf")" "$(dirname "$qt6ct_conf")"
rm -rf "$kvantum_user_themes/$selected_theme" 2>/dev/null || true
cp -a "$theme_root/$selected_theme" "$kvantum_user_themes/" 2>/dev/null || {
  kdialog --title "$app_title" --error "Failed to copy theme into your home directory." 2>/dev/null || true
  exit 1
}

cat >"$kvantum_conf" <<EOF
[General]
theme=${selected_theme}
EOF

cat >"$plasma_env_file" <<'EOF'
#!/usr/bin/env bash
export QT_QPA_PLATFORMTHEME=qt6ct
EOF
chmod +x "$plasma_env_file" 2>/dev/null || true

cat >"$qt5ct_conf" <<EOF
[Appearance]
standard_dialogs=default
style=kvantum
EOF

cat >"$qt6ct_conf" <<EOF
[Appearance]
standard_dialogs=default
style=kvantum
EOF

kdialog --title "$app_title" --msgbox "Catppuccin Kvantum applied for your user.\n\nTheme: $selected_theme\n\nYour next login will already use this by default. Restart currently open Qt apps to refresh them now." 2>/dev/null || true

