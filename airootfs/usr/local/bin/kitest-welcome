#!/bin/bash
[[ -f /home/kitest/.kitest_done ]] && exit 0

kdialog --title "Welcome to Kitest OS" --msgbox "Welcome to Kitest OS — a Tor-forwarded, kernel-hacking friendly Arch live environment.

Configure mirrors and install apps with pacman or Flatpak when you are ready.

This dialog runs once per user."

touch /home/kitest/.kitest_done
