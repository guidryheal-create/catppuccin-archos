[Desktop Entry]
Type=Application
Version=1.0
Name=Install Kitest OS
Comment=Run hybrid install (archinstall + Kitest post-install)
Exec=konsole -e /usr/local/bin/kitest-install-hybrid
TryExec=/usr/local/bin/kitest-install-hybrid
Icon=system-software-install
Terminal=false
StartupNotify=true
Categories=System;Installer;
Keywords=Install;archinstall;Kitest;
