#!/usr/bin/ash

parse_arg_value() {
  local key="$1" arg
  for arg in $(cat /proc/cmdline); do
    case "${arg}" in
      "${key}"=*)
        printf '%s\n' "${arg#*=}"
        return 0
        ;;
    esac
  done
  return 1
}

has_arg() {
  local key="$1" arg
  for arg in $(cat /proc/cmdline); do
    [ "${arg}" = "${key}" ] && return 0
  done
  return 1
}

run_hook() {
  local desired_label

  has_arg "cow_autodetect=1" || return 0

  desired_label="$(parse_arg_value cow_label 2>/dev/null || true)"
  [ -n "${desired_label}" ] || desired_label="KITEST_PERSIST"

  # Phase 1 safety: do not mount/scan candidate disks in initramfs.
  # Only accept an explicitly labeled persistence partition.
  [ -e "/dev/disk/by-label/${desired_label}" ] && return 0
  return 0
}
