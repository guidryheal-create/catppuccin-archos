#!/usr/bin/ash

parse_arg_value() {
  local key="$1" arg
  for arg in $(cat /proc/cmdline); do
    case "${arg}" in
      "${key}"=*)
        printf '%s\n' "${arg#*=}"
        return 0
        ;;
    esac
  done
  return 1
}

has_arg() {
  local key="$1" arg
  for arg in $(cat /proc/cmdline); do
    [ "${arg}" = "${key}" ] && return 0
  done
  return 1
}

run_hook() {
  local desired_label archiso_uuid dev real type uuid best_real
  local best_sectors sectors base

  has_arg "cow_autodetect=1" || return 0

  desired_label="$(parse_arg_value cow_label 2>/dev/null || true)"
  [ -n "${desired_label}" ] || desired_label="KITEST_PERSIST"
  [ -e "/dev/disk/by-label/${desired_label}" ] && return 0

  archiso_uuid="$(parse_arg_value archisosearchuuid 2>/dev/null || true)"

  # When several Linux filesystems exist (e.g. QEMU: ISO on vda + persist on vdb),
  # picking the first /dev/disk/by-uuid/* match is nondeterministic and can point
  # the overlay at the wrong device. Prefer the largest eligible partition whose
  # UUID is not the archiso search UUID.
  best_real=""
  best_sectors=0

  for dev in /dev/disk/by-uuid/*; do
    [ -e "${dev}" ] || continue
    real="$(readlink -f "${dev}" 2>/dev/null || true)"
    [ -b "${real}" ] || continue

    type="$(blkid -s TYPE -o value "${real}" 2>/dev/null || true)"
    uuid="$(blkid -s UUID -o value "${real}" 2>/dev/null || true)"
    case "${type}" in
      ext2|ext3|ext4|xfs|btrfs|f2fs) ;;
      *) continue ;;
    esac
    [ -n "${archiso_uuid}" ] && [ "${uuid}" = "${archiso_uuid}" ] && continue

    base="${real##*/}"
    [ -r "/sys/class/block/${base}/size" ] || continue
    sectors="$(cat "/sys/class/block/${base}/size" 2>/dev/null || echo 0)"
    [ "${sectors:-0}" -gt "${best_sectors:-0}" ] || continue
    best_sectors="${sectors}"
    best_real="${real}"
  done

  [ -n "${best_real}" ] || return 0

  mkdir -p /dev/disk/by-label
  ln -sf "${best_real}" "/dev/disk/by-label/${desired_label}"
  return 0
}
