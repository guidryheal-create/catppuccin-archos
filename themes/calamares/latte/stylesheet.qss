/* Calamares — Catppuccin Latte sidebar (Kitest theme). */
#sidebarMenuApp {
	padding: 3px;
	background-color: #4c4f69;
	color: #eff1f5;
}
#sidebarApp {
	background-color: #4c4f69;
	color: #eff1f5;
}
QListWidget::item {
	color: #dce0e8;
	padding: 4px;
}
QListWidget::item:selected {
	background-color: #acb0be;
	color: #4c4f69;
}
#mainText { font: bold 16px; }
QWidget { font: 16px; }
